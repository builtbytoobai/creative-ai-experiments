# Copy this file to .env and fill in your API keys.
# Never commit .env — it is in .gitignore.

# OpenAI API key — used by review.py for ChatGPT (GPT-4o) architecture reviews
# Get yours at: platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API key — used by review.py for Gemini UX/product reviews
# Get yours at: aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
